# === ESG-Assure Configuration ===
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- API Keys ---
GROQ_API_KEY=your_groq_api_key_here

# --- Paths (relative to project root) ---
DATA_DIR=./data
PLOTS_DIR=./plots
REPORTS_DIR=./reports

# --- Data Generation ---
NUM_SUPPLIERS=1000
RANDOM_SEED=42

# --- LLM Configuration ---
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.1
LLM_SYSTEM_PROMPT=You are a rigid, no-nonsense ESG Auditor at EY. Output ONLY the requested audit memo format.

# --- Rate Limiting ---
RATE_LIMIT_DELAY=1.5
MAX_RETRIES=3
MAX_CONCURRENT_REQUESTS=5

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json
